# ReplyWise production environment template.
# Copy to the production environment, replace every placeholder with a secret,
# and never commit the populated file.

REPLY_ENV=prod
SERVICE_NAME=reply-backend

# PostgreSQL 16 / asyncpg. URL-encode the password in DATABASE_URL when needed.
POSTGRES_PASSWORD=replace-with-a-strong-password
DATABASE_URL=postgresql+asyncpg://replywise:replace-with-url-encoded-password@postgres:5432/replywise

JWT_SECRET=replace-with-a-long-random-secret
SERVER_PEPPER=replace-with-a-long-random-pepper

OPENAI_API_KEY=replace-with-production-openai-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=30

REVENUECAT_SECRET_API_KEY=replace-with-production-revenuecat-key
REVENUECAT_PROJECT_ID=replace-with-revenuecat-project-id
REVENUECAT_ENTITLEMENT_ID=premium
REVENUECAT_SUBSCRIPTION_PRODUCT_ID=premium_yearly:yearly
REVENUECAT_CREDIT_PRODUCT_MAP=credits_10:10,credits_50:50,credits_100:100

MOCK_AI_ENABLED=false
DEV_TOOLS_ENABLED=false
ALLOWED_ORIGINS=*

EXPLAIN_DAILY_LIMIT=10
FREE_LIFETIME_LIMIT=5
GENERATION_RATE_PER_MINUTE=8
IDEMPOTENCY_TTL_SECONDS=86400
