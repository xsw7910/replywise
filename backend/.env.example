# ReplyWise backend environment template.
# Copy to .env, fill secrets locally/on the VM, and never commit .env.

# Runtime
REPLY_ENV=dev
# APP_ENV is retained as a backwards-compatible fallback when REPLY_ENV is unset.
APP_ENV=dev
SERVICE_NAME=reply-backend
DATABASE_URL=sqlite+aiosqlite:///./replywise.db

# Security
# Generate each value with:
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
SERVER_PEPPER=

# OpenAI
# A non-empty key is required in production because production rejects mock AI.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=30

# RevenueCat (API v2 — v2-compatible secret key required)
# Find REVENUECAT_PROJECT_ID in the RevenueCat dashboard → Project Settings.
REVENUECAT_SECRET_API_KEY=
REVENUECAT_PROJECT_ID=
REVENUECAT_ENTITLEMENT_ID=premium
REVENUECAT_SUBSCRIPTION_PRODUCT_ID=premium_yearly:yearly
# Maps purchase product_id -> credits granted, as "product_id:credits,..."
# Merged on top of the in-code store defaults (credits_10:10, credits_50:50,
# credits_100:100). RevenueCat API v2 /purchases may report INTERNAL product
# ids like "prod733d52bcdd" instead of the store identifier — look these up in
# the RevenueCat Products API or Dashboard and add them here, e.g.:
# REVENUECAT_CREDIT_PRODUCT_MAP=credits_10:10,credits_50:50,credits_100:100,prod733d52bcdd:10
REVENUECAT_CREDIT_PRODUCT_MAP=credits_10:10,credits_50:50,credits_100:100

# Local-only feature flags. Production startup rejects true values.
MOCK_AI_ENABLED=false
DEV_TOOLS_ENABLED=false

# CORS: "*" is suitable for native clients; use a comma-separated allowlist
# if browser clients are introduced.
ALLOWED_ORIGINS=*

# Limits
EXPLAIN_DAILY_LIMIT=10
FREE_LIFETIME_LIMIT=5
GENERATION_RATE_PER_MINUTE=8
IDEMPOTENCY_TTL_SECONDS=86400
