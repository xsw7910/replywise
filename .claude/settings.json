{
  "permissions": {
    "allow": [
      "Bash(cd *)",
      "Bash(flutter build *)",
      "Bash(adb install *)",
      "Bash(Select-Object *)",
      "Bash(./.venv/Scripts/python.exe *)",
      "Bash(./../backend/.venv/Scripts/python.exe *)",
      "Bash(.venv/Scripts/*)",
      "PowerShell(adb devices)"
    ],
    "deny": [
      "Bash(git push)",
      "Bash(git push:*)",
      "Bash(git reset --hard:*)",
      "Bash(git reset:*)",
      "Bash(git clean:*)",
      "Bash(rm -rf:*)",
      "Bash(del /s:*)",
      "Bash(rmdir /s:*)"
    ],
    "defaultMode": "bypassPermissions"
  }
}
